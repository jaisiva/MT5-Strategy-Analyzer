# ============================================================================
# MT5 Strategy Analyzer
# .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# ----------------------------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------------------------
# Build
# ----------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ----------------------------------------------------------------------------
# Packaging
# ----------------------------------------------------------------------------
pip-wheel-metadata/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ----------------------------------------------------------------------------
# MyPy
# ----------------------------------------------------------------------------
.mypy_cache/

# ----------------------------------------------------------------------------
# Ruff
# ----------------------------------------------------------------------------
.ruff_cache/

# ----------------------------------------------------------------------------
# Black
# ----------------------------------------------------------------------------
.cache/

# ----------------------------------------------------------------------------
# PyCharm
# ----------------------------------------------------------------------------
.idea/

# ----------------------------------------------------------------------------
# VS Code
# ----------------------------------------------------------------------------
.vscode/

# ----------------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# macOS
# ----------------------------------------------------------------------------
.DS_Store

# ----------------------------------------------------------------------------
# Windows
# ----------------------------------------------------------------------------
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Output Reports (Generated)
# ----------------------------------------------------------------------------
output/
reports/
exports/

# Keep folder structure
!output/.gitkeep
!reports/.gitkeep
!exports/.gitkeep

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------
*.tmp
*.temp
*.bak

# ----------------------------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------------------------
.env
.env.*

# ----------------------------------------------------------------------------
# Local Configuration
# ----------------------------------------------------------------------------
config/local.json

# ----------------------------------------------------------------------------
# Python Version Manager
# ----------------------------------------------------------------------------
.python-version

# ----------------------------------------------------------------------------
# Installer Logs
# ----------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------------------------------------------------------
# Generated Charts
# ----------------------------------------------------------------------------
charts/

# Keep folder
!charts/.gitkeep

# ----------------------------------------------------------------------------
# Generated Excel Files
# ----------------------------------------------------------------------------
*.xlsx

# Keep sample data under version control
!samples/*.xlsx

# ----------------------------------------------------------------------------
# Generated CSV Files
# ----------------------------------------------------------------------------
*.csv
!samples/*.csv

# ----------------------------------------------------------------------------
# Generated PDF Reports
# ----------------------------------------------------------------------------
*.pdf
!docs/*.pdf

# ----------------------------------------------------------------------------
# Backup Files
# ----------------------------------------------------------------------------
*.orig
*.rej
*.swp

# ----------------------------------------------------------------------------
# Local Database (Future)
# ----------------------------------------------------------------------------
*.db
*.sqlite3

# ----------------------------------------------------------------------------
# PyInstaller (Future)
# ----------------------------------------------------------------------------
*.spec

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.pid
*.seed
```
